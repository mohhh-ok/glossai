ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GLOSSAI_MODEL=claude-opus-4-8
# LLM backend: anthropic (default, uses ANTHROPIC_API_KEY) | claude-code (uses your local `claude` CLI login instead of an API key)
GLOSSAI_LLM_PROVIDER=anthropic
# TTS backend: say (default, macOS only, no API key needed) | openai (uses OPENAI_API_KEY)
GLOSSAI_TTS_PROVIDER=say
# Voice name: for `say`, a macOS voice (default Samantha, see `say -v '?'`); for `openai`, a gpt-4o-mini-tts voice (default alloy)
GLOSSAI_TTS_VOICE=
# SQLite cache/history DB path (default data/glossai.db, directory auto-created)
GLOSSAI_DB=
